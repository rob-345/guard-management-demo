meta {
  name: SubscribeEvent
  type: http
  seq: 26
}

post {
  url: http://{{device_host}}/ISAPI/Event/notification/subscribeEvent
  body: xml
  auth: digest
}

headers {
  Content-Type: application/xml
}

auth:digest {
  username: {{username}}
  password: {{password}}
}

body:xml {
  <SubscribeEvent version="2.0">
    <eventMode>all</eventMode>
    <channelMode>all</channelMode>
  </SubscribeEvent>
}
