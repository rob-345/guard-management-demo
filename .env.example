# Core app configuration
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=guard_management_demo
JWT_SECRET=replace-with-a-long-random-secret
GRIDFS_BUCKET_NAME=guard_photos

# Public app origin used for Hikvision callbacks and signed photo URLs.
# Use a LAN-reachable or public URL for real terminals. Do not use localhost for device callbacks.
APP_BASE_URL=http://192.168.0.100:3000

# Shared secret for /api/events/ingest
EVENT_INGEST_SECRET=replace-with-a-shared-ingest-secret

# Default bootstrap admin user
ADMIN_EMAIL=admin@westec.co.zw
ADMIN_PASSWORD=Password@123
ADMIN_FIRST_NAME=System
ADMIN_LAST_NAME=Administrator

# Hikvision backend defaults used by the app adapter
HIKVISION_PROTOCOL=http
HIKVISION_TIMEOUT_MS=15000
HIKVISION_RETRIES=1

# Smoke test configuration
SMOKE_BASE_URL=http://127.0.0.1:3000
SMOKE_EMAIL=admin@westec.co.zw
SMOKE_PASSWORD=Password@123
SMOKE_INGEST_SECRET=replace-with-a-smoke-ingest-secret

# Manual live-device SDK test configuration
HIKVISION_TEST_HOST=192.168.0.179
HIKVISION_TEST_USERNAME=admin
HIKVISION_TEST_PASSWORD=replace-with-terminal-password
HIKVISION_TEST_PROTOCOL=http
HIKVISION_TEST_FDID=1
HIKVISION_TEST_FACE_LIB_TYPE=blackFD
# Optional
HIKVISION_TEST_TERMINAL_NO=
# Set to 1 only when a person is standing in front of the terminal and you want to run the live capture test.
HIKVISION_TEST_CAPTURE_REQUIRED=0
# Set to 1 only when you want the live webhook subscribe/unsubscribe test to run.
HIKVISION_TEST_WEBHOOK_SUBSCRIBE_REQUIRED=0
